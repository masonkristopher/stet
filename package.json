{
  "name": "sideye",
  "version": "0.4.1",
  "private": true,
  "description": "Read-only companion TUI with IDE-grade insight into agent changes",
  "license": "MIT",
  "repository": "github:jimmy-guzman/sideye",
  "bin": {
    "sideye": "./src/main.tsx"
  },
  "type": "module",
  "scripts": {
    "build": "bun run script/build.ts --single --skip-install",
    "build:dist": "bun script/build.ts",
    "check": "bun run lint && bun run format:check && bun test && bun run typecheck && bun run knip",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "prepare": "effect-language-service patch",
    "screenshots": "bun run script/screenshots.ts",
    "sideye": "bun run src/main.tsx",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "knip": "knip"
  },
  "dependencies": {
    "@opentui/core": "0.4.2",
    "@opentui/solid": "0.4.2",
    "@pierre/diffs": "1.2.12",
    "effect": "4.0.0-beta.92",
    "shiki": "4.3.0",
    "solid-js": "1.9.13"
  },
  "devDependencies": {
    "@effect/language-service": "0.86.2",
    "@types/bun": "1.3.14",
    "@types/node": "25.9.4",
    "knip": "6.23.0",
    "lefthook": "2.1.9",
    "oxfmt": "0.57.0",
    "oxlint": "1.72.0",
    "oxlint-tsgolint": "0.23.0",
    "typescript": "6.0.3"
  }
}
