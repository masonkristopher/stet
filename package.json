{
  "name": "sideye",
  "version": "0.1.6",
  "private": true,
  "description": "Read-only companion TUI for CLI coding agents",
  "license": "MIT",
  "repository": "github:jimmy-guzman/sideye",
  "bin": {
    "sideye": "./src/main.tsx"
  },
  "type": "module",
  "scripts": {
    "build": "bun build ./src/main.tsx --target bun --compile --outfile ${TMPDIR:-/tmp}/sideye-build-check",
    "build:dist": "bun script/build.ts",
    "check": "bun run lint && bun run format:check && bun test && bun run typecheck && bun run knip",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "sideye": "bun run src/main.tsx",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "knip": "knip"
  },
  "dependencies": {
    "@effect/atom-react": "4.0.0-beta.83",
    "@opentui/core": "^0.4.0",
    "@opentui/react": "^0.4.0",
    "effect": "4.0.0-beta.83",
    "react": "^19.2.4"
  },
  "devDependencies": {
    "@effect/language-service": "^0.86.2",
    "@types/bun": "^1.3.0",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.4",
    "knip": "^6.16.1",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "typescript": "^6.0.3"
  }
}
