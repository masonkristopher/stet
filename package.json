{
  "name": "sideye",
  "version": "0.2.4",
  "private": true,
  "description": "Read-only companion TUI for CLI coding agents",
  "license": "MIT",
  "repository": "github:jimmy-guzman/sideye",
  "bin": {
    "sideye": "./src/main.tsx"
  },
  "type": "module",
  "scripts": {
    "build": "bun run script/build.ts --single --skip-install",
    "build:dist": "bun script/build.ts",
    "check": "bun run lint && bun run format:check && bun test && bun run typecheck && bun run knip",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "sideye": "bun run src/main.tsx",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "knip": "knip"
  },
  "dependencies": {
    "@opentui/core": "0.4.1",
    "@opentui/solid": "0.4.1",
    "effect": "4.0.0-beta.83",
    "solid-js": "1.9.13"
  },
  "devDependencies": {
    "@effect/language-service": "^0.86.2",
    "@types/bun": "^1.3.14",
    "@types/node": "^25.9.3",
    "knip": "^6.17.1",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0",
    "oxlint-tsgolint": "^0.23.0",
    "typescript": "^6.0.3"
  }
}
