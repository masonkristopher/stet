{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn", "oxc", "react", "react-perf"],
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "perf": "warn"
  },
  "rules": {
    "eqeqeq": "error",
    "react/react-in-jsx-scope": "off"
  },
  "ignorePatterns": ["dist", ".agents"],
  "env": {
    "builtin": true
  }
}
