{
  "compilerOptions": {
    "lib": ["ESNext", "DOM"],
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "jsx": "react-jsx",
    "jsxImportSource": "@opentui/react",
    "strict": true,
    "skipLibCheck": true,
    "types": ["bun"],
    "noEmit": true,
    "plugins": [{ "name": "@effect/language-service" }]
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "test/**/*.ts", "script/**/*.ts"]
}
