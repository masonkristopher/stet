{
  "name": "sideye",
  "version": "0.1.3",
  "private": true,
  "description": "Read-only companion TUI for CLI coding agents",
  "license": "MIT",
  "repository": "github:jimmy-guzman/sideye",
  "bin": {
    "sideye": "./src/main.tsx"
  },
  "type": "module",
  "scripts": {
    "build": "bun build ./src/main.tsx --target bun --compile --outfile ${TMPDIR:-/tmp}/sideye-build-check",
    "build:dist": "bun script/build.ts",
    "check": "bun run lint && bun run format:check && bun test && bun run typecheck",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "sideye": "bun run src/main.tsx",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "@opentui/core": "^0.4.0",
    "@opentui/react": "^0.4.0",
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.0",
    "@types/react": "^19.0.0",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "typescript": "^5.9.0"
  }
}
